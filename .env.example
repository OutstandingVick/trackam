# Server
PORT=3000
NODE_ENV=development

# Public base URL (used in docs/badges). No trailing slash.
BASE_URL=http://localhost:3000

# PostgreSQL connection
DATABASE_URL=postgres://trackam:trackam@localhost:5432/trackam

# Secret used to sign dashboard session cookies (change this!)
JWT_SECRET=change-me-to-a-long-random-string

# How long (in seconds) a gap between heartbeats still counts as
# continuous coding time. WakaTime's default is 15 minutes (900s).
HEARTBEAT_TIMEOUT_SECONDS=900
